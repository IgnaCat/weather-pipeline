# =============================================
# weather-pipeline — Variables de entorno
# Copiá este archivo como .env y completá los valores
# NUNCA commitees el .env con credenciales reales
# =============================================

# --- Configuración general ---
PIPELINE_ENV=development          # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# --- Rutas de datos ---
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_ANALYTICS_PATH=data/analytics

# --- NOAA NEXRAD (S3 público, no requiere credenciales) ---
NEXRAD_BUCKET=noaa-nexrad-level2
NEXRAD_STATION=KBUF               # Código de 4 letras de la estación (ej: KBUF = Buffalo NY)
AWS_DEFAULT_REGION=us-east-1      # Región del bucket público de NOAA

# Si tenés cuenta AWS propia (opcional, para mejor rate limit):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Open-Meteo (no requiere API key) ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# --- DuckDB ---
DUCKDB_PATH=data/catalog.duckdb

# --- Pipeline ---
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_WAIT_MIN=1         # segundos
PIPELINE_RETRY_WAIT_MAX=60        # segundos
PIPELINE_RATE_LIMIT_CALLS=10      # llamadas por período
PIPELINE_RATE_LIMIT_PERIOD=1      # segundos
